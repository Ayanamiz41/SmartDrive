    <resultMap id="base_result_map" type="com.smartdrive.auth.entity.UserInfo">
        <id column="user_id" property="userId"/>
        <result column="nick_name" property="nickName"/>
        <result column="email" property="email"/>
        <result column="avatar" property="avatar"/>
        <result column="password" property="password"/>
        <result column="join_time" property="joinTime"/>
        <result column="last_login_time" property="lastLoginTime"/>
        <result column="status" property="status"/>
        <result column="use_space" property="useSpace"/>
        <result column="total_space" property="totalSpace"/>
        <result column="department_id" property="departmentId"/>
        <result column="is_admin" property="isAdmin"/>
    </resultMap>

    <sql id="base_column_list">
        user_id,nick_name,email,avatar,password,join_time,last_login_time,status,use_space,total_space,department_id,is_admin
    </sql>

    <sql id="base_query_condition">
        <if test=" query.userId != null and query.userId!= ''">and user_id= #{query.userId}</if>
        <if test=" query.nickName != null and query.nickName!= ''">and nick_name= #{query.nickName}</if>
        <if test=" query.email != null and query.email!= ''">and email= #{query.email}</if>
        <if test=" query.status != null">and status= #{query.status}</if>
    </sql>

    <sql id="base_query_condition_extend">
        <if test=" query.userIdFuzzy != null and query.userIdFuzzy!= null ">and user_id like concat('%', #{query.userIdFuzzy}, '%')</if>
        <if test=" query.nickNameFuzzy != null and query.nickNameFuzzy!= null ">and nick_name like concat('%', #{query.nickNameFuzzy}, '%')</if>
        <if test=" query.emailFuzzy != null and query.emailFuzzy!= null ">and email like concat('%', #{query.emailFuzzy}, '%')</if>
        <if test=" query.keyword != null and query.keyword != '' ">and (nick_name like concat('%', #{query.keyword}, '%') or email like concat('%', #{query.keyword}, '%'))</if>
    </sql>

    <sql id="query_condition">
        <where>
            <include refid="base_query_condition"/>
            <include refid="base_query_condition_extend"/>
        </where>
    </sql>

    <select id="selectList" resultMap="base_result_map">
        SELECT <include refid="base_column_list"/> FROM user_info
        <include refid="query_condition"/>
        <if test="query.orderBy != null">order by ${query.orderBy}</if>
        <if test="query.simplePage != null">limit ${query.simplePage.start}, ${query.simplePage.end}</if>
    </select>

    <select id="selectCount" resultType="java.lang.Integer">
        SELECT COUNT(1) FROM user_info <include refid="query_condition"/>
    </select>

