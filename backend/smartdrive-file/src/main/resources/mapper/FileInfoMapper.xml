		<select id="selectUserIdsByNickName" resultType="java.lang.String">
			SELECT user_id FROM user_info WHERE nick_name LIKE concat('%', #{nickNameFuzzy}, '%')
		</select>

		<!-- ES 搜索后根据 ID 列表查文件详情（不含 user_info JOIN，昵称走 Feign） -->
		<select id="selectBasicByIds" resultMap="base_result_map">
			SELECT f.*, d.name AS department_name
			FROM file_info f
			LEFT JOIN department d ON f.department_id = d.id
			WHERE f.file_id IN
			<foreach collection="fileIds" item="id" open="(" separator="," close=")">
				#{id}
			</foreach>
			ORDER BY FIELD(f.file_id,
			<foreach collection="fileIds" item="id" separator=",">
				#{id}
			</foreach>
			)
		</select>

		<!-- ES 不可用时 MySQL 回退分页查询 -->
		<select id="selectListPage" resultMap="base_result_map">
			SELECT f.*, d.name AS department_name
			FROM file_info f
			LEFT JOIN department d ON f.department_id = d.id
			<where>
				<include refid="base_query_condition"/>
				<include refid="base_query_condition_extend"/>
			</where>
			ORDER BY f.last_update_time DESC
