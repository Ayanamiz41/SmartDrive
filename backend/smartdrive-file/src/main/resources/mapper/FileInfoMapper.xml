<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
		"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.smartdrive.file.mapper.FileInfoMapper">
	<!-- 实体映射-->
	<resultMap id="base_result_map" type="com.smartdrive.file.entity.FileInfo">
		<!--文件id-->
		<result column="file_id" property="fileId"/>
		<!--用户id-->
		<result column="user_id" property="userId"/>
		<!--文件md5值-->
		<result column="file_md5" property="fileMd5"/>
		<!--父级文件id-->
		<result column="file_pid" property="filePid"/>
		<!--文件大小 单位字节-->
		<result column="file_size" property="fileSize"/>
		<!--文件名-->
		<result column="file_name" property="fileName"/>
		<!--文件封面-->
		<result column="file_cover" property="fileCover"/>
		<!--文件路径-->
		<result column="file_path" property="filePath"/>
		<!--创建时间-->
		<result column="create_time" property="createTime"/>
		<!--最近更新时间-->
		<result column="last_update_time" property="lastUpdateTime"/>
		<!--0：文件  1：目录-->
		<result column="folder_type" property="folderType"/>
		<!--文件分类 1：视频  2：音频  3：图片  4：文档  5：其他-->
		<result column="file_category" property="fileCategory"/>
		<!--文件类型 1：视频  2：音频  3：图片  4：pdf  5：doc  6：excel  7：txt  8：code  9：zip  10：其他-->
		<result column="file_type" property="fileType"/>
		<!--状态 0：转码中  1：转码失败  2：转码成功  -->
		<result column="status" property="status"/>
		<!--进入回收站时间-->
		<result column="recycle_time" property="recycleTime"/>
		<!-- 删除标记 0：删除 1：回收站  2：正常-->
			<result column="del_flag" property="delFlag"/>
			<!-- 归档标记 0=正常 1=已归档 -->
			<result column="archived" property="archived"/>
			<!-- 归档时间 -->
			<result column="archived_time" property="archivedTime"/>
			<!--所属部门-->
			<result column="department_id" property="departmentId"/>
			<!--最后编辑者ID-->
			<result column="last_update_user_id" property="lastUpdateUserId"/>
			</resultMap>

	<!-- 通用查询结果列 -->
	<sql id="base_column_list">
		file_id,user_id,file_md5,file_pid,file_size,file_name,file_cover,file_path,create_time,last_update_time,folder_type,file_category,file_type,status,recycle_time,del_flag,department_id,summary,archived,archived_time
	</sql>

	<!-- 基础查询条件 -->
	<sql id="base_query_condition">
		<if test=" query.fileId != null and query.fileId!= ''">
			and file_id= #{query.fileId}
		</if>
		<if test=" query.userId != null and query.userId!= '' and (query.deptMode == null or !query.deptMode)">
			and f.user_id= #{query.userId}
		</if>
		<if test=" query.fileMd5 != null and query.fileMd5!= ''">
			and file_md5= #{query.fileMd5}
		</if>
		<if test=" query.filePid != null and query.filePid!= ''">
			and file_pid= #{query.filePid}
		</if>
		<if test=" query.fileSize != null">
			and file_size= #{query.fileSize}
		</if>
		<if test=" query.fileName != null and query.fileName!= ''">
			and file_name= #{query.fileName}
		</if>
		<if test=" query.fileCover != null and query.fileCover!= ''">
			and file_cover= #{query.fileCover}
		</if>
		<if test=" query.filePath != null and query.filePath!= ''">
			and file_path= #{query.filePath}
		</if>
		<if test=" query.createTime != null">
			and create_time= #{query.createTime}
		</if>
		<if test=" query.lastUpdateTime != null">
			and last_update_time= #{query.lastUpdateTime}
		</if>
		<if test=" query.folderType != null">
			and folder_type= #{query.folderType}
		</if>
		<if test=" query.fileCategory != null">
			and file_category= #{query.fileCategory}
		</if>
		<if test=" query.fileType != null">
			and file_type= #{query.fileType}
		</if>
		<if test=" query.status != null">
			and f.status= #{query.status}
		</if>
		<if test=" query.recycleTime != null">
			and recycle_time= #{query.recycleTime}
		</if>
		<if test=" query.delFlag != null">
			and del_flag= #{query.delFlag}
		</if>
		<if test=" query.archived != null">
			and f.archived= #{query.archived}
		</if>
		<!-- 回收站列表专用（excludeNestedRecycle）：排除父文件夹也在回收站的子文件。
		     不能按 delFlag==1 全局生效，否则 recoverFileBatch/delFileBatch 的递归子文件收集查询也会被过滤，级联失效 -->
		<if test=" query.excludeNestedRecycle != null and query.excludeNestedRecycle == true">
			and (file_pid = '0' or not exists (
				select 1 from file_info p where p.file_id = f.file_pid and p.del_flag = 1
			))
		</if>
		<if test=" query.departmentIdIsNull != null and query.departmentIdIsNull == true">
			and f.department_id IS NULL
		</if>
		<if test=" query.departmentId != null and query.departmentId != ''">
			and f.department_id= #{query.departmentId}
		</if>
		<choose>
			<when test=" query.deptMode != null and query.deptMode == true">
				<!-- 部门空间：只看部门文件 -->
				<if test=" query.departmentIds != null and query.departmentIds.size() > 0">
					and f.department_id IN
					<foreach collection="query.departmentIds" item="deptId" open="(" close=")" separator=",">
						#{deptId}
					</foreach>
				</if>
				<if test=" query.departmentIds == null or query.departmentIds.size() == 0">
					and 1=0
				</if>
			</when>
			<when test=" query.departmentIds != null and query.departmentIds.size() > 0">
				<!-- 混合模式（回收站等）：个人文件 + 部门文件 -->
				and (f.user_id = #{query.userId} OR f.department_id IN
				<foreach collection="query.departmentIds" item="deptId" open="(" close=")" separator=",">
					#{deptId}
				</foreach>)
			</when>
			<when test=" query.deptMode != null">
				<!-- 我的文件：只看个人文件 -->
				<if test=" query.userId != null and query.userId != ''">
					and f.user_id = #{query.userId} and f.department_id IS NULL
				</if>
			</when>
			<otherwise>
				<!-- 默认模式（查重等），不限制 department_id -->
				<if test=" query.userId != null and query.userId != ''">
					and f.user_id = #{query.userId}
				</if>
			</otherwise>
		</choose>
	</sql>

	<!-- 扩展查询条件 -->
	<sql id="base_query_condition_extend">
		<if test=" query.fileIdFuzzy != null and query.fileIdFuzzy!= '' ">
			and file_id like concat('%', #{query.fileIdFuzzy}, '%')
		</if>
		<if test=" query.userIdFuzzy != null and query.userIdFuzzy!= '' ">
			and user_id like concat('%', #{query.userIdFuzzy}, '%')
		</if>
		<if test=" query.fileMd5Fuzzy != null and query.fileMd5Fuzzy!= '' ">
			and file_md5 like concat('%', #{query.fileMd5Fuzzy}, '%')
		</if>
		<if test=" query.filePidFuzzy != null and query.filePidFuzzy!= '' ">
			and file_pid like concat('%', #{query.filePidFuzzy}, '%')
		</if>
		<if test=" query.fileNameFuzzy != null and query.fileNameFuzzy!= '' ">
			and file_name like concat('%', #{query.fileNameFuzzy}, '%')
		</if>
		<if test=" query.fileCoverFuzzy != null and query.fileCoverFuzzy!= '' ">
			and file_cover like concat('%', #{query.fileCoverFuzzy}, '%')
		</if>
		<if test=" query.filePathFuzzy != null and query.filePathFuzzy!= '' ">
			and file_path like concat('%', #{query.filePathFuzzy}, '%')
		</if>
		<if test=" query.createTimeStart != null and query.createTimeStart!= '' ">
			<![CDATA[ and create_time >= str_to_date(#{query.createTimeStart}, '%Y-%m-%d') ]]>
		</if>
		<if test=" query.createTimeEnd != null and query.createTimeEnd!= '' ">
			<![CDATA[ and create_time < date_sub(str_to_date(#{query.createTimeEnd}, '%Y-%m-%d'), interval -1 day) ]]>
		</if>
		<if test=" query.lastUpdateTimeStart != null and query.lastUpdateTimeStart!= '' ">
			<![CDATA[ and last_update_time >= str_to_date(#{query.lastUpdateTimeStart}, '%Y-%m-%d') ]]>
		</if>
		<if test=" query.lastUpdateTimeEnd != null and query.lastUpdateTimeEnd!= '' ">
			<![CDATA[ and last_update_time < date_sub(str_to_date(#{query.lastUpdateTimeEnd}, '%Y-%m-%d'), interval -1 day) ]]>
		</if>
		<if test=" query.recycleTimeStart != null and query.recycleTimeStart!= '' ">
			<![CDATA[ and recycle_time >= str_to_date(#{query.recycleTimeStart}, '%Y-%m-%d') ]]>
		</if>
		<if test=" query.recycleTimeEnd != null and query.recycleTimeEnd!= '' ">
			<![CDATA[ and recycle_time < date_sub(str_to_date(#{query.recycleTimeEnd}, '%Y-%m-%d'), interval -1 day) ]]>
		</if>
		 <if test="query.fileIdArray!=null and query.fileIdArray.length>0">
			 and file_id in (<foreach collection="query.fileIdArray" item="item" separator=",">#{item}</foreach>)
		 </if>
		<if test="query.excludeFileIdArray!=null and query.excludeFileIdArray.length>0">
			and file_id not in (<foreach collection="query.excludeFileIdArray" item="item" separator=",">#{item}</foreach>)
		</if>
		<if test="query.queryExpire!=null and query.queryExpire" >
			<![CDATA[ and f.recycle_time < date_sub(now(), interval 10 day) ]]>
		</if>
	</sql>

	<!-- 通用查询条件 -->
	<sql id="query_condition">
		<where>
			<include refid="base_query_condition"/>
			<include refid="base_query_condition_extend"/>
		</where>
	</sql>

	<!-- 查询列表（带部门名称） -->
	<select id="selectList" resultMap="base_result_map">
		SELECT f.*,
		       d.name AS department_name
		FROM file_info f
		LEFT JOIN department d ON f.department_id = d.id
		<include refid="query_condition"/>
		<if test="query.orderBy != null">
			order by ${query.orderBy}
		</if>
		<if test="query.simplePage != null">
			limit ${query.simplePage.start}, ${query.simplePage.end}
		</if>
	</select>

	<!-- 查询数量 -->
	<select id="selectCount" resultType="java.lang.Integer">
		SELECT COUNT(1) FROM file_info f
		<include refid="query_condition"/>
	</select>

